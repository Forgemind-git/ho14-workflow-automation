# ---------------------------------------------------------------------------
# OPTIONAL — advanced only. The course path uses Claude Cowork with your
# Claude.ai subscription: no API key, no .env, no terminal. See README.md.
# These settings only matter if you run the optional Python script (main.py)
# yourself. No ANTHROPIC_API_KEY is needed anywhere here.
# ---------------------------------------------------------------------------

# Folder to watch for new CSV files
INPUT_DIR=input

# Folder where processed copies are written (prefixed with "processed_")
OUTPUT_DIR=output

# Folder where originals are archived after processing
PROCESSED_DIR=processed

# Log file path
LOG_FILE=run.log

# Watchdog poll interval in seconds
POLL_INTERVAL=2.0

# Seconds to wait after file detection before reading (allows slow copies)
FILE_SETTLE_DELAY=1.0
