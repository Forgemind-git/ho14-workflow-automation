# Gmail address to send FROM
SMTP_USER=you@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASS=abcd efgh ijkl mnop

# Email address to send the report TO
REPORT_TO=team@yourcompany.com

# Optional: override the "from" display address (defaults to SMTP_USER)
# REPORT_FROM=reports@yourcompany.com

# SMTP server settings (defaults work for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Path to the metrics CSV file to report on
METRICS_CSV=metrics.csv

# Log files
LOG_FILE=run.log
SENDS_LOG=sends.log
