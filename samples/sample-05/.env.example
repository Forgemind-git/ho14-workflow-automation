# Path to the primary source CSV (authoritative data)
SOURCE_A=source_a.csv

# Path to the secondary/destination CSV (gets rows appended)
SOURCE_B=source_b.csv

# Column name used as the unique identifier / primary key
ID_COLUMN=id

# Log file path
LOG_FILE=run.log

# Delta log (JSON Lines) -- one record per sync run
DELTA_LOG=delta_log.jsonl
