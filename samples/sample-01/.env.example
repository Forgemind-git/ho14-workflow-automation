# Target page to scrape
TARGET_URL=https://quotes.toscrape.com/

# CSS selector to extract (e.g. "span.text", "h1.price", ".headline a")
CSS_SELECTOR=span.text

# Output CSV file path (relative to script dir or absolute)
OUTPUT_CSV=scraped_data.csv

# Log file path
LOG_FILE=run.log

# HTTP request timeout in seconds
REQUEST_TIMEOUT=15
